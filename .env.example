# === Personal Portfolio — variabili ambiente (COPIA in .env, non committare .env) ===

# --- Storage ---
# Path del DB canonico dentro il container backend
DB_PATH=/data/portfolio.db
# Path della replica read-only letta da Metabase (copia atomica post-import, ADR-0004)
REPLICA_PATH=/replica/portfolio_replica.db

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Metabase (Fase 3) ---
METABASE_PORT=3000

# --- Backup (Fase 4) ---
# Trigger backup: manuale sempre; automatico all'avvio solo se true (ADR-0008)
BACKUP_ON_STARTUP=false
# Path locale dove scrivere i backup (montato come volume Docker, vedi docker-compose.yml)
BACKUP_DIR=/backups
# Path della Service Account key MONTATA a runtime (mai nel repo, ADR-0011)
GOOGLE_SA_KEY_PATH=/secrets/service_account.json
# ID cartella Google Drive destinazione backup
GDRIVE_BACKUP_FOLDER_ID=
# Quante copie storiche conservare
BACKUP_RETENTION=12

# --- AI (Fase 6) ---
# API key fornita dall'utente, provider-agnostico
AI_API_KEY=
AI_PROVIDER=
# Model id del provider selezionato (default: linea flash-lite GA di Gemini, ADR-0023 p.3)
AI_MODEL=gemini-3.1-flash-lite

# --- Import ---
# Anno minimo da importare (ADR-0012)
IMPORT_MIN_YEAR=2026
